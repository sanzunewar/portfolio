# Copy this file to ".env" for local development and fill in real values.
# NEVER commit your real .env file.

# Generate a secret key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Keep True locally, set to False in production (Render).
DJANGO_DEBUG=True

# Comma-separated hosts allowed to serve the site (production).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Full origins allowed to POST (production), comma-separated.
# e.g. https://sanjeevshrestha.info.np,https://www.sanjeevshrestha.info.np
DJANGO_CSRF_TRUSTED_ORIGINS=

# Your AI provider key — server-side only, never exposed to the browser.
AI_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001
